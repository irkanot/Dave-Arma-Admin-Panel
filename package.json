{
  "name": "arma-server-web-admin",
  "description": "ArmA3 Server Management Backbone.js App",
  "version": "1.4.8",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "check": "npm run lint && npm test && npm run build && npm run test:e2e",
    "install-windows-service": "winser -i -a -c",
    "uninstall-windows-service": "winser -r -x -c",
    "lint": "standard --verbose",
    "start": "node app.js",
    "test": "node node_modules/mocha/bin/mocha --recursive",
    "test:e2e": "node test/e2e/smoke.js"
  },
  "standard": {
    "env": [
      "mocha"
    ],
    "ignore": [
      "assets/**"
    ]
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "arma-class-parser": "^1.1.1",
    "arma-server": "0.0.10",
    "async": "^2.6.4",
    "backbone": "1.3.3",
    "backbone.bootstrap-modal": "https://github.com/powmedia/backbone.bootstrap-modal/archive/632210077c2424be2ee6ea2aafe0d3fe016ae524.tar.gz",
    "backbone.marionette": "^4.1.3",
    "body-parser": "^1.17.1",
    "bootstrap": "^5.3.8",
    "css-loader": "^7.1.4",
    "express": "^4.15.2",
    "express-session": "^1.19.0",
    "filesize": "^3.1.0",
    "fs.extra": "~1.3.2",
    "gamedig": "^5.3.3",
    "glob": "^7.1.6",
    "jquery": "^3.5.0",
    "jquery.iframe-transport": "^1.0.0",
    "ladda": "1.0.5",
    "lodash": "^4.17.10",
    "morgan": "^1.8.1",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.18",
    "serve-static": "^1.12.1",
    "slugify": "^1.1.0",
    "socket.io": "^4.8.3",
    "style-loader": "^4.0.0",
    "sweetalert": "^1.1.3",
    "underscore": "^1.9.1",
    "userhome": "^1.0.0",
    "webpack": "^5.108.4",
    "webpack-dev-middleware": "^8.0.3",
    "winser": "^1.0.2"
  },
  "devDependencies": {
    "mocha": "^11.3.0",
    "playwright": "^1.61.1",
    "should": "^13.2.3",
    "standard": "^17.1.2",
    "supertest": "^7.2.2",
    "timekeeper": "^2.2.0",
    "webpack-cli": "^6.0.1"
  }
}
